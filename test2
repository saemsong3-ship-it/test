import json
from collections import defaultdict, deque

def normalize_str(s):
    return s.strip().lower()

def normalize_version(v):
    return normalize_str(v).replace(".release", "").replace("-jre", "")

def make_key(package, version):
    return f"{normalize_str(package)}@{normalize_version(version)}"

def parse_osv_results(file_path):
    vulns = []
    with open(file_path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("URL"):
                continue

            parts = line.split("|")
            if len(parts) < 6:
                continue

            url, cvss, ecosystem, package, version, source = parts

            key = make_key(package, version)

            vulns.append({
                "key": key,
                "package": normalize_str(package),
                "version": normalize_version(version),
                "cvss": cvss.strip(),
                "url": url.strip()
            })
    return vulns

def parse_sbom(sbom_path):
    with open(sbom_path, 'r', encoding='utf-8') as f:
        sbom = json.load(f)

    dependencies = sbom.get("dependencies", [])
    components = sbom.get("components", [])

    graph = defaultdict(list)
    purl_to_name = {}

    for comp in components:
        purl = comp.get("purl")
        name = comp.get("name")
        version = comp.get("version")
        group = comp.get("group")

        if group:
            key = make_key(f"{group}:{name}", version)
        else:
            key = make_key(name, version)

        if purl:
            purl_to_name[purl] = key

    for dep in dependencies:
        ref = dep.get("ref")
        depends_on = dep.get("dependsOn", [])

        if ref in purl_to_name:
            src = purl_to_name[ref]
            for d in depends_on:
                if d in purl_to_name:
                    dst = purl_to_name[d]
                    graph[src].append(dst)

    return graph

def is_match(sbom_key, osv_key):
    return normalize_str(sbom_key) == normalize_str(osv_key)

def find_paths(graph, target_key):
    paths = []

    all_nodes = set(graph.keys())
    all_deps = set(d for deps in graph.values() for d in deps)
    roots = all_nodes - all_deps

    for root in roots:
        queue = deque([(root, [root])])
        while queue:
            node, path = queue.popleft()

            if is_match(node, target_key):
                paths.append(" -> ".join(path))
                continue

            if node in graph:
                for nxt in graph[node]:
                    if nxt not in path:
                        queue.append((nxt, path + [nxt]))

    return paths

def analyze(sbom_file, osv_file, output_file):
    vulns = parse_osv_results(osv_file)
    graph = parse_sbom(sbom_file)

    with open(output_file, 'w', encoding='utf-8') as f:
        f.write("PACKAGE,VERSION,CVSS,URL,FOUND,DEPENDENCY_PATHS\n")

        for v in vulns:
            paths = find_paths(graph, v["key"])
            found = "TRUE" if paths else "FALSE"

            if paths:
                path_str = " | ".join(paths)
            else:
                path_str = "NOT_FOUND"

            f.write(f"{v['package']},{v['version']},{v['cvss']},{v['url']},{found},{path_str}\n")

    print(f"[+] Done. Output: {output_file}")

if __name__ == "__main__":
    analyze("sbom.json", "osv_scanner_result.txt", "final_vuln_result.csv")